---
// Over Ons page — new route, static content, design-system Header/Footer.
import BaseHead from "../components/BaseHead.astro";
import BaseScript from "../components/BaseScript.astro";
import Header from "../components/design-system/Header.astro";
import Footer from "../components/design-system/Footer.astro";
import SocialIcons from "../components/design-system/SocialIcons.astro";
import {
  getNavLinks,
  FOOTER_COLUMNS,
  FOOTER_BOTTOM_LEFT,
  FOOTER_TAGLINE,
  PARTNER_LABEL,
} from "../lib/siteNav";

const canonicalURL = "https://www.cinematen.be/over-ons";
const navLinks = getNavLinks("overons");
---

<html lang="nl">
  <head>
    <BaseHead
      title="Over ons | Cinematen.be"
      description="Wat zijn Cinematen? Yorrick & Maarten zijn je film- en tv-gidsen — hilarisch commentaar en deskundige meningen over alles wat er te zien is."
      canonicalURL={canonicalURL}
    />
  </head>
  <body class="cn-overons-body">
    <Header links={navLinks} partnerLabel={PARTNER_LABEL}>
      <img
        slot="logo"
        src="/images/cinematen-white-horizontal.png"
        alt="Cinematen.be"
        width="185"
        height="28"
        style="height:28px;width:auto;"
      />
      <img
        slot="partner-logo"
        src="/images/kinepolis.png"
        alt="Kinepolis Antwerpen"
        width="28"
        height="28"
        style="height:28px;width:auto;display:block;"
      />
    </Header>

    <main class="cn-overons">
      <div class="cn-overons__grid">
        <div class="cn-overons__copy">
          <h1 class="cn-overons__title">Wat zijn Cinematen?</h1>
          <p>
            Ben je het beu om door al die streamingdiensten te scrollen zonder
            enig idee wat je moet kijken? Sta je vaak in de grote inkomhal van
            de Kinepolis en weet je totaal niet welke film je best kan zien?
          </p>
          <p>
            Laat Yorrick &amp; Maarten je film- en tv-gidsen zijn! Met hun
            hilarische commentaar en "deskundige" meningen weet je altijd wat
            je moet kijken. En zo niet, dan kun je op zijn minst lachen om hun
            geflodder.
          </p>
          <iframe
            title="Cinematen Podcast op Spotify"
            class="cn-overons__spotify"
            src="https://open.spotify.com/embed/show/19O8JqKPSbQWek15vG3sig?utm_source=generator&theme=0"
            width="100%"
            height="152"
            frameborder="0"
            allowfullscreen
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            loading="lazy"></iframe>
        </div>
        <div class="cn-overons__media">
          <img
            src="/images/cinematen-boys.png"
            alt="Yorrick en Maarten van Cinematen"
            width="560"
            height="373"
            class="cn-overons__image"
          />
        </div>
      </div>
    </main>

    <Footer columns={FOOTER_COLUMNS} bottomLeft={FOOTER_BOTTOM_LEFT}>
      <img
        slot="logo"
        src="/images/cinematen-white-horizontal.png"
        alt="Cinematen.be"
        width="172"
        height="26"
        style="height:26px;width:auto;"
      />
      <Fragment slot="tagline">{FOOTER_TAGLINE}</Fragment>
      <Fragment slot="social-icons"><SocialIcons /></Fragment>
    </Footer>

    <BaseScript />

    <style>
      .cn-overons-body {
        margin: 0;
        background: var(--surface);
      }
      .cn-overons {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 64px var(--space-margin-desktop) 80px;
      }
      .cn-overons__grid {
        display: grid;
        grid-template-columns: 1.1fr 1fr;
        gap: 56px;
        align-items: center;
      }
      .cn-overons__title {
        font-family: var(--font-sans);
        font-weight: var(--font-headline-weight);
        font-size: 44px;
        line-height: var(--text-headline-lg-line);
        color: var(--on-surface);
        margin: 0 0 24px;
      }
      .cn-overons__copy p {
        font-family: var(--font-sans);
        font-size: 18px;
        line-height: 1.7;
        color: var(--on-surface-variant);
        margin: 0 0 20px;
      }
      .cn-overons__spotify {
        border-radius: var(--radius-lg);
        display: block;
        border: none;
        margin-top: 4px;
      }
      .cn-overons__media {
        display: flex;
        align-items: center;
        height: 100%;
      }
      .cn-overons__image {
        width: 100%;
        height: auto;
        border-radius: var(--radius-2xl);
        display: block;
        box-shadow: var(--shadow-lg);
      }

      @media (max-width: 900px) {
        .cn-overons__grid {
          grid-template-columns: 1fr;
          gap: 32px;
        }
        .cn-overons__media {
          order: -1;
        }
      }
      @media (max-width: 640px) {
        .cn-overons {
          padding: 48px var(--space-margin-mobile) 64px;
        }
        .cn-overons__title {
          font-size: var(--text-headline-lg-mobile-size);
          line-height: var(--text-headline-lg-mobile-line);
        }
        .cn-overons__copy p {
          font-size: 16px;
        }
      }
    </style>
  </body>
</html>
