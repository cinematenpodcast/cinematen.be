---
// Import necessary components
import ListingShell from "../../../layouts/ListingShell.astro";
import ArticleCard from "../../../components/design-system/ArticleCard.astro";
import Pagination from "../../../components/design-system/Pagination.astro";
import ReviewsFilterChips from "../../../components/ReviewsFilterChips.astro";
import PodcastCard from "../../../components/design-system/PodcastCard.astro";

import { getCollection } from "astro:content";
import type { Page } from "astro";
import { extractPreview } from "../../../lib/textPreview";
import { formatCardDate, ratingOutOfTen } from "../../../lib/format";

export async function getStaticPaths({ paginate }) {
    // Load all review posts
    const allReviewPostsRaw = await getCollection("reviews");

    // Sort posts by date in descending order
    const sortedPostsRaw = allReviewPostsRaw.sort((a, b) => {
        return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
    });

        // Helper function to ensure clean ID without .mdx extension
        function getCleanId(id) {
            return id ? id.replace(/\.mdx$/, '') : '';
        }

        // Map to format expected by pagination
        const sortedPosts = sortedPostsRaw.map(post => ({
            url: `/reviews&blogs/${getCleanId(post.id)}`,
            frontmatter: post.data,
            rawContent: post.data.summary || extractPreview(post.body),
        }));

    // Paginate the sorted array
    return paginate(sortedPosts, { pageSize: 8 });
}

// Explicit `Page<any>` annotation: with real, per-file union types now
// generated for `CollectionEntry<"reviews">`, TS's inference through the
// sort/map chain above collapses to `never` for the props type without
// this — a known practical union-complexity ceiling, unrelated to the
// actual data being fine at runtime.
const { page } = Astro.props as { page: Page<any> };

exclude_from_search: true
---

<ListingShell navActive="reviews">
  <div class="cn-listing__inner">
    <h1>Reviews &amp; Blogs</h1>
    <p class="cn-listing__intro">
      Diepgaande analyses, recensies en beschouwingen over de films en series die er echt toe doen.
    </p>
    <ReviewsFilterChips />
    <div class="cn-listing__grid">
      {page.data.map((post) => {
        return (
          <ArticleCard title={post.frontmatter.title} href={post.url} excerpt={post.frontmatter.summary ?? post.rawContent} rating={ratingOutOfTen(post.frontmatter.rating)}>
            <img slot="image" src={post.frontmatter.thumbnail} alt={post.frontmatter.title} loading="lazy" />
            <span slot="meta">
              {formatCardDate(post.frontmatter.date)}
              {post.frontmatter.schrijver ? ` · ${post.frontmatter.schrijver}` : ""}
            </span>
          </ArticleCard>
        );
      })}
    </div>
    <div class="cn-listing__pagination">
      <Pagination page={page.currentPage} totalPages={page.lastPage} hrefBase="/reviews&blogs/pages/:page" />
    </div>
  </div>
  <div class="cn-listing__podcast">
    <PodcastCard />
  </div>
</ListingShell>
