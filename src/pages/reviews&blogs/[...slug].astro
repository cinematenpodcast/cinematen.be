---
import { getCollection } from "astro:content";
import ReviewLayout from "../../layouts/ReviewLayout.astro";
import { YouTube } from 'astro-embed';
import EmptySpaceS from "../../components/EmptySpaceS.astro";
import EmptySpaceM from "../../components/EmptySpaceM.astro";
import EmptySpaceL from "../../components/EmptySpaceL.astro";

export async function getStaticPaths() {
  const posts = await getCollection("reviews");

  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.mdx$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;

// Ensure post exists
if (!post) {
  return Astro.redirect('/reviews&blogs', 404);
}

const frontmatter = { ...post.data, slug: post.slug };

// Render the MDX content directly for production
const { Content } = await post.render();
---

<ReviewLayout frontmatter={frontmatter}>
  <Content components={{ YouTube, EmptySpaceS, EmptySpaceM, EmptySpaceL }} />
</ReviewLayout>
