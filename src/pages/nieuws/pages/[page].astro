---
// Import necessary components
import ListingShell from "../../../layouts/ListingShell.astro";
import ArticleCard from "../../../components/design-system/ArticleCard.astro";
import Pagination from "../../../components/design-system/Pagination.astro";
import NieuwsFilterChips from "../../../components/NieuwsFilterChips.astro";
import PodcastCard from "../../../components/design-system/PodcastCard.astro";

import { getCollection } from "astro:content";
import type { Page } from "astro";
import { extractPreview } from "../../../lib/textPreview";
import { formatCardDate, slugFromEntryId } from "../../../lib/format";

export async function getStaticPaths({ paginate }) {
    // Load all news posts
    const allNieuwsPostsRaw = await getCollection("nieuws");
    const allNieuwsPosts = allNieuwsPostsRaw.filter(post => !post.data.draft);

    // Sort posts by date in descending order
    const sortedPosts = allNieuwsPosts.sort((a, b) => {
        return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
    });

    // Map to format expected by pagination
    const mappedPosts = sortedPosts.map(post => ({
        url: `/nieuws/${slugFromEntryId(post.id)}`,
        frontmatter: post.data,
        rawContent: post.data.summary || extractPreview(post.body),
    }));

    // Paginate the sorted array
    return paginate(mappedPosts, { pageSize: 8 });
}

// Explicit `Page<any>` annotation: with real, per-file union types now
// generated for `CollectionEntry<"nieuws">` (~760 members), TS's inference
// through the filter/sort/map chain above collapses to `never` for the
// props type without this — a known practical union-complexity ceiling,
// unrelated to the actual data being fine at runtime.
const { page } = Astro.props as { page: Page<any> };

exclude_from_search: true
---

<ListingShell navActive="nieuws">
  <div class="cn-listing__inner">
    <h1>Film &amp; TV Nieuws</h1>
    <p class="cn-listing__intro">
      Blijf op de hoogte van de laatste nieuwtjes, casting updates, trailers en geruchten uit de
      wondere wereld van cinema en televisie.
    </p>
    <NieuwsFilterChips active="all" />
    <div class="cn-listing__grid">
      {page.data.map((post) => (
        <ArticleCard title={post.frontmatter.title} href={post.url} excerpt={post.rawContent}>
          <img slot="image" src={post.frontmatter.thumbnail} alt={post.frontmatter.title} loading="lazy" />
          <span slot="meta">{formatCardDate(post.frontmatter.date)}</span>
        </ArticleCard>
      ))}
    </div>
    <div class="cn-listing__pagination">
      <Pagination page={page.currentPage} totalPages={page.lastPage} hrefBase="/nieuws/pages/:page" />
    </div>
  </div>
  <div class="cn-listing__podcast">
    <PodcastCard />
  </div>
</ListingShell>
