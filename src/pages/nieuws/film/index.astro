---
import { getCollection } from "astro:content";
import ListingShell from "../../../layouts/ListingShell.astro";
import ArticleCard from "../../../components/design-system/ArticleCard.astro";
import NieuwsFilterChips from "../../../components/NieuwsFilterChips.astro";
import PodcastCard from "../../../components/design-system/PodcastCard.astro";
import { extractPreview } from "../../../lib/textPreview";
import { formatCardDate, slugFromEntryId } from "../../../lib/format";

const allNieuws = await getCollection("nieuws");
const filmNieuws = allNieuws
  .filter(p => !p.data.draft && p.data.soort?.toLowerCase() === 'film')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<ListingShell
  navActive="nieuws"
  useExcludeHead={false}
  title="Film Nieuws | Cinematen.be"
  description="Het laatste filmnews: blockbusters, releases, trailers en meer. Cinematen.be houdt je op de hoogte."
  canonicalURL="https://www.cinematen.be/nieuws/film/"
>
  <div class="cn-listing__inner">
    <h1>Film nieuws</h1>
    <p class="cn-listing__intro">Het laatste filmnieuws: blockbusters, releases, trailers en meer.</p>
    <NieuwsFilterChips active="film" />
    <div class="cn-listing__grid">
      {filmNieuws.map(post => (
        <ArticleCard title={post.data.title} href={`/nieuws/${slugFromEntryId(post.id)}`} excerpt={post.data.summary || extractPreview(post.body)}>
          <img slot="image" src={post.data.thumbnail} alt={post.data.title} loading="lazy" />
          <span slot="meta">{formatCardDate(post.data.date)}</span>
        </ArticleCard>
      ))}
    </div>
  </div>
  <div class="cn-listing__podcast">
    <PodcastCard />
  </div>
</ListingShell>
