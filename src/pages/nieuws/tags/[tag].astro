---
// Redirects the bare /nieuws/tags/:tag to its first paginated page.
// Must be server-rendered (not prerendered): a prerendered page can't emit a real
// HTTP redirect, only a static meta-refresh stub, which briefly flashes a blank
// "Redirecting to: ..." page in the browser before continuing.
export const prerender = false;

const { tag } = Astro.params;

return Astro.redirect(`/nieuws/tags/${tag}/1`, 301);
---
