---
// Import necessary components
import ListingShell from "../../../../layouts/ListingShell.astro";
import ArticleCard from "../../../../components/design-system/ArticleCard.astro";
import Pagination from "../../../../components/design-system/Pagination.astro";
import NieuwsFilterChips from "../../../../components/NieuwsFilterChips.astro";
import PodcastCard from "../../../../components/design-system/PodcastCard.astro";

import { getCollection } from "astro:content";
import { extractPreview } from "../../../../lib/textPreview";
import { formatCardDate, slugFromEntryId } from "../../../../lib/format";

export async function getStaticPaths({ paginate }) {
    const allPostsRaw = (await getCollection("nieuws")).filter(post => !post.data.draft);

    const allPosts = allPostsRaw.map(post => {
        const cleanId = slugFromEntryId(post.id);
        return {
            url: `/nieuws/${cleanId}`,
            frontmatter: post.data,
            rawContent: () => post.data.summary || extractPreview(post.body, 200),
        };
    });

    // Get all unique tags and their posts
    const tagMap = new Map();

    allPosts.forEach((post) => {
        if (post.frontmatter.title && post.frontmatter.tags) {
            post.frontmatter.tags.forEach((tag) => {
                const formattedTag = tag.toLowerCase().replace(/:/g, '');
                if (!tagMap.has(formattedTag)) {
                    tagMap.set(formattedTag, []);
                }
                tagMap.get(formattedTag).push(post);
            });
        }
    });

    // Create paginated routes for each tag
    const routes = [];
    for (const [tag, posts] of tagMap.entries()) {
        const sortedPosts = posts.sort((a, b) =>
            new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
        );

        const paginatedPages = paginate(sortedPosts, {
            params: { tag },
            props: { tag },
            pageSize: 8
        });

        routes.push(...paginatedPages);
    }

    return routes;
}

const { page, tag } = Astro.props;

exclude_from_search: true
---

<ListingShell navActive="nieuws">
  <div class="cn-listing__inner">
    <h1>Film &amp; TV nieuws — {tag}</h1>
    <p class="cn-listing__intro">Alle nieuwsartikelen getagd met &ldquo;{tag}&rdquo;.</p>
    <NieuwsFilterChips />
    <div class="cn-listing__grid">
      {page.data.map((post) => (
        <ArticleCard title={post.frontmatter.title} href={post.url} excerpt={post.rawContent()}>
          <img slot="image" src={post.frontmatter.thumbnail} alt={post.frontmatter.title} loading="lazy" />
          <span slot="meta">{formatCardDate(post.frontmatter.date)}</span>
        </ArticleCard>
      ))}
    </div>
    <div class="cn-listing__pagination">
      <Pagination page={page.currentPage} totalPages={page.lastPage} hrefBase={`/nieuws/tags/${tag}/:page`} />
    </div>
  </div>
  <div class="cn-listing__podcast">
    <PodcastCard />
  </div>
</ListingShell>
