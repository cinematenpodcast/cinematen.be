---
import { getCollection } from "astro:content";
import NieuwsLayout from "../../layouts/NieuwsLayout.astro";
import { slugFromEntryId } from "../../lib/format";

export async function getStaticPaths() {
  const posts = await getCollection("nieuws", (post) => !post.data.draft);

  return posts.map((post) => {
    return { params: { slug: slugFromEntryId(post.id) }, props: { post } };
  });
}

const { post } = Astro.props;

if (!post) {
  return Astro.redirect('/nieuws', 404);
}

const frontmatter = { ...post.data, slug: post.slug };
const { Content } = await post.render();
---

<NieuwsLayout frontmatter={frontmatter}>
  <Content />
</NieuwsLayout>
