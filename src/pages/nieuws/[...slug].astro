---
import { getCollection } from "astro:content";
import NieuwsLayout from "../../layouts/NieuwsLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("nieuws", (post) => !post.data.draft);

  return posts.map((post) => {
    const cleanId = post.id.replace(/\.mdx$/, '');
    return { params: { slug: cleanId }, props: { post } };
  });
}

const { post } = Astro.props;

if (!post) {
  return Astro.redirect('/nieuws', 404);
}

const frontmatter = { ...post.data, slug: post.slug };
const { Content } = await post.render();
---

<NieuwsLayout frontmatter={frontmatter}>
  <Content />
</NieuwsLayout>
