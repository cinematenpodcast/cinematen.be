---
import { getCollection } from "astro:content";
import ListingShell from "../../../layouts/ListingShell.astro";
import ArticleCard from "../../../components/design-system/ArticleCard.astro";
import CategoryBadge from "../../../components/design-system/CategoryBadge.astro";
import NieuwsFilterChips from "../../../components/NieuwsFilterChips.astro";
import BasePodcastBanner from "../../../components/BasePodcastBanner.astro";
import { extractPreview } from "../../../lib/textPreview";
import { formatCardDate } from "../../../lib/format";

function getCleanId(id) {
  return id ? id.replace(/\.mdx$/, '') : '';
}

const allNieuws = await getCollection("nieuws");
// Categories reduced to just "Film" / "TV" (was "TV & Series") -- see .pages.yml.
const serieNieuws = allNieuws
  .filter(p => !p.data.draft && p.data.soort?.toLowerCase() === 'tv')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<ListingShell
  navActive="nieuws"
  useExcludeHead={false}
  title="Serie Nieuws | Cinematen.be"
  description="Het laatste serienieuws: nieuwe seizoenen, streaming releases, trailers. Cinematen.be volgt het allemaal."
  canonicalURL="https://www.cinematen.be/nieuws/serie/"
>
  <div class="cn-listing__inner">
    <h1>Serie nieuws</h1>
    <p class="cn-listing__intro">Het laatste serienieuws: nieuwe seizoenen, streaming releases, trailers.</p>
    <NieuwsFilterChips active="tv" />
    <div class="cn-listing__grid">
      {serieNieuws.map(post => (
        <ArticleCard title={post.data.title} href={`/nieuws/${getCleanId(post.id)}`} excerpt={post.data.summary || extractPreview(post.body)}>
          <img slot="image" src={post.data.thumbnail} alt={post.data.title} loading="lazy" />
          <CategoryBadge slot="badge" label="TV" tone="tv" />
          <span slot="meta">{formatCardDate(post.data.date)}</span>
        </ArticleCard>
      ))}
    </div>
  </div>
  <div class="cn-listing__podcast">
    <BasePodcastBanner />
  </div>
</ListingShell>
