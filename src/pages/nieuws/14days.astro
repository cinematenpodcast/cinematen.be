---
// Import necessary components
import ListingShell from "../../layouts/ListingShell.astro";
import ArticleCard from "../../components/design-system/ArticleCard.astro";
import CategoryBadge from "../../components/design-system/CategoryBadge.astro";
import NieuwsFilterChips from "../../components/NieuwsFilterChips.astro";

import { getCollection } from "astro:content";
import { extractPreview } from "../../lib/textPreview";
import { formatCardDate } from "../../lib/format";

// Helper function to ensure clean ID without .mdx extension
function getCleanId(id) {
    return id ? id.replace(/\.mdx$/, '') : '';
}

const allNieuwsPostsRaw = (await getCollection("nieuws")).filter(post => !post.data.draft);
const allNieuwsPosts = allNieuwsPostsRaw.map(post => {
    const cleanId = getCleanId(post.id);
    return {
        url: `/nieuws/${cleanId}`,
        frontmatter: post.data,
        rawContent: () => extractPreview(post.body, 200),
    };
});

// Define the date threshold (replace 'your_date_string' with the desired date)
const thresholdDate = new Date('2024-09-21');

// Filter posts based on the threshold date
const filteredPosts = allNieuwsPosts.filter(post => new Date(post.frontmatter.date) >= thresholdDate);

exclude_from_search: true
---

<ListingShell navActive="nieuws">
  <div class="cn-listing__inner">
    <h1>Film &amp; TV nieuws</h1>
    <NieuwsFilterChips active="all" />
    <div class="cn-listing__grid">
      {filteredPosts
        .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())
        .map((post) => (
          <ArticleCard title={post.frontmatter.title} href={post.url} excerpt={post.rawContent()}>
            <img slot="image" src={post.frontmatter.thumbnail} alt={post.frontmatter.title} loading="lazy" />
            {post.frontmatter.soort && (
              <CategoryBadge
                slot="badge"
                label={`${post.frontmatter.soort} nieuws`}
                tone={post.frontmatter.soort.toLowerCase() === "tv" ? "tv" : "film"}
              />
            )}
            <span slot="meta">{formatCardDate(post.frontmatter.date)}</span>
          </ArticleCard>
        ))}
    </div>
  </div>
</ListingShell>
