---
// Nieuws article detail — redesigned per `Artikel.dc.html`.
// Wrapped by src/pages/nieuws/[...slug].astro (untouched, still passes
// `frontmatter` + slotted MDX `<Content />`). Same data/meta pipeline as
// before (BaseHeadNieuws, RandomReviews) — only the visual chrome around
// the article body changed. RelatedNieuws's "Misschien ook interessant"
// section was removed: it duplicated RandomReviews's own related-content
// grid on this same page. BasePodcastBanner was replaced with the shared
// PodcastCard component (real Spotify show embed, matching Artikel.dc.html)
// placed at the end of the article body, before the related-content grid.
import BaseHeadNieuws from "../components/BaseHeadNieuws.astro";
import Header from "../components/design-system/Header.astro";
import Footer from "../components/design-system/Footer.astro";
import SocialIcons from "../components/design-system/SocialIcons.astro";
import PodcastCard from "../components/design-system/PodcastCard.astro";
import RandomReviews from "../components/RandomReviews.astro";
import { readFileSync } from "fs";
import { join } from "path";
import { formatCardDate, formatDateISO, readingTime } from "../lib/format";
import { getNavLinks, FOOTER_COLUMNS, FOOTER_BOTTOM_LEFT, FOOTER_TAGLINE, PARTNER_LABEL } from "../lib/siteNav";

const { frontmatter } = Astro.props;

// Fallback meta-description source for the (still-common, pre-backfill) case
// where nieuws.summary is blank — read straight from the MDX file on disk.
// Also the source for the hero's reading-time pill, which needs the actual
// rendered body word count (see src/lib/format.ts readingTime).
function getPlainTextFromMDX(slug) {
  if (!slug) return "";
  try {
    const filePath = join(process.cwd(), "src/content/nieuws", `${slug}.mdx`);
    const content = readFileSync(filePath, "utf-8");
    const withoutFrontmatter = content.replace(/^---[\s\S]*?---\s*\n\n?/m, "");
    return withoutFrontmatter
      .replace(/#{1,6}\s+/g, "")
      .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
      .replace(/\*\*([^*]+)\*\*/g, "$1")
      .replace(/\*([^*]+)\*/g, "$1")
      .replace(/!\[([^\]]*)\]\([^)]+\)/g, "")
      .replace(/\s+/g, " ")
      .trim();
  } catch {
    return "";
  }
}

// Generate canonical URL for this news article
const canonicalURL = `https://www.cinematen.be${Astro.url.pathname}`;
const rawUrlSlug = Astro.url.pathname.split("/").filter(Boolean).pop();
let urlSlug = rawUrlSlug;
try {
  urlSlug = decodeURIComponent(rawUrlSlug);
} catch {
  // rawUrlSlug wasn't percent-encoded; use as-is.
}
const plainText = getPlainTextFromMDX(urlSlug) || getPlainTextFromMDX(frontmatter.slug);
const metaDescription = frontmatter.summary || plainText.substring(0, 155) || undefined;
const minutesToRead = readingTime(plainText);

const displayDate = formatCardDate(frontmatter.date);
// `trailer` is a plain YouTube video ID in frontmatter (e.g. "f_bKjZeJBBI"),
// not a full URL — see src/content/config.ts. youtube-nocookie.com avoids
// setting third-party cookies until the visitor actually plays the video.
const trailerSrc = frontmatter.trailer ? `https://www.youtube-nocookie.com/embed/${frontmatter.trailer}` : null;
---

<html lang="nl">
    <head>
      <BaseHeadNieuws
          title={frontmatter.title}
          thumbnail={frontmatter.thumbnail}
          description={metaDescription}
          canonicalURL={canonicalURL}
          publishedDate={frontmatter.date}
          modifiedDate={frontmatter.date}
          author={frontmatter.schrijver}
        />
    </head>
    <body>
        <div class="cn-page">
            <Header links={getNavLinks("nieuws")} partnerLabel={PARTNER_LABEL}>
                <img slot="logo" src="/images/cinematen-white-horizontal.png" alt="Cinematen.be" width="185" height="28" />
                <img slot="partner-logo" src="/images/kinepolis.png" alt="Kinepolis" width="34" height="34" />
            </Header>

            <main>
                <section class="cn-article-hero">
                    <div class="cn-article-hero__media" aria-hidden="true">
                        <img src={frontmatter.thumbnail} alt="" loading="eager" decoding="sync" fetchpriority="high" />
                        <div class="cn-article-hero__scrim"></div>
                    </div>
                    <div class="cn-article-hero__content">
                        <h1>{frontmatter.title}</h1>
                        <div class="cn-article-hero__meta">
                            {displayDate && (
                                <span class="cn-article-hero__date" data-pagefind-meta={`date:${formatDateISO(frontmatter.date)}`}>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                                        <line x1="16" y1="2" x2="16" y2="6"></line>
                                        <line x1="8" y1="2" x2="8" y2="6"></line>
                                        <line x1="3" y1="10" x2="21" y2="10"></line>
                                    </svg>
                                    {displayDate}
                                </span>
                            )}
                            <span class="cn-article-hero__reading-time">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <circle cx="12" cy="12" r="9"></circle>
                                    <polyline points="12 7 12 12 16 14"></polyline>
                                </svg>
                                {minutesToRead} min leestijd
                            </span>
                            <span class="cn-article-hero__author">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                                Door {frontmatter.schrijver || "de redactie van Cinematen"}
                            </span>
                        </div>
                    </div>
                </section>

                <article class="cn-article-prose">
                    {frontmatter.summary && <p>{frontmatter.summary}</p>}
                    <slot />

                    {trailerSrc && (
                        <div class="cn-article-trailer">
                            <h2>Bekijk de trailer</h2>
                            <div class="cn-article-trailer__frame">
                                <iframe
                                    src={trailerSrc}
                                    title="Trailer"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; fullscreen; gyroscope; picture-in-picture"
                                    loading="lazy"
                                ></iframe>
                            </div>
                        </div>
                    )}

                    <PodcastCard />
                </article>

                <RandomReviews currentSlug={frontmatter.slug} />
            </main>

            <Footer columns={FOOTER_COLUMNS} bottomLeft={FOOTER_BOTTOM_LEFT}>
                <img slot="logo" src="/images/cinematen-white-horizontal.png" alt="Cinematen.be" width="172" height="26" />
                <Fragment slot="tagline">{FOOTER_TAGLINE}</Fragment>
                <Fragment slot="social-icons">
                    <SocialIcons />
                </Fragment>
            </Footer>
        </div>
    </body>
</html>

<style>
    .cn-page {
        min-height: 100dvh;
        background: var(--surface);
        color: var(--on-surface);
    }

    .cn-article-hero {
        position: relative;
        width: 100%;
        min-height: 60vh;
        display: flex;
        align-items: flex-end;
        padding-bottom: 32px;
    }
    .cn-article-hero__media {
        position: absolute;
        inset: 0;
        z-index: 0;
    }
    .cn-article-hero__media img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        /* Same fix as the homepage hero — anchor to the top so the top of
           the image is always visible instead of center-cropping. The
           bottom scrim gradient below is untouched. */
        object-position: center top;
    }
    .cn-article-hero__scrim {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(13, 23, 48, 0.95) 0%, rgba(13, 23, 48, 0.3) 55%, transparent 100%);
    }
    .cn-article-hero__content {
        position: relative;
        z-index: 1;
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 0 var(--space-margin-desktop) 48px;
        width: 100%;
        box-sizing: border-box;
    }
    .cn-article-hero__content h1 {
        font-family: var(--font-sans);
        font-weight: 800;
        letter-spacing: -0.01em;
        font-size: 44px;
        line-height: 1.1;
        color: var(--on-surface);
        margin: 0 0 24px;
        max-width: 820px;
    }
    .cn-article-hero__meta {
        display: flex;
        gap: 16px;
        align-items: center;
        flex-wrap: wrap;
    }
    .cn-article-hero__date,
    .cn-article-hero__reading-time,
    .cn-article-hero__author {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: var(--font-sans);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--on-surface-variant);
    }
    .cn-article-hero__author {
        background: var(--surface-container-high);
        color: var(--on-surface);
        border-radius: var(--radius-full);
        padding: 4px 12px;
    }
    /* Matches Artikel.dc.html's reading-time pill exactly — #1f2937 is a
       one-off literal in the original design, not tied to any color token
       (same case as the hero CTA button's literal #fff/#0a1128). */
    .cn-article-hero__reading-time {
        background: #1f2937;
        color: var(--on-surface);
        border-radius: var(--radius-full);
        padding: 4px 12px;
    }

    .cn-article-prose {
        max-width: 900px;
        margin: 0 auto;
        padding: 48px var(--space-margin-mobile) 64px;
        font-family: var(--font-sans);
        font-size: 18px;
        line-height: 1.6;
        color: var(--on-surface);
    }
    /* public/style.css ships a global `p { color: var(--grey); ... }` rule
       (a plain type selector) that directly targets every <p> the MDX body
       renders. A directly-matching rule always wins over an inherited value
       regardless of specificity, so `.cn-article-prose { color: on-surface }`
       above — which only sets color on the ancestor, never on `p` itself —
       never actually reaches any paragraph. `:first-of-type` below happens to
       look fine only because its own selector also targets `p` directly and
       out-specifies the global rule; every later paragraph fell through to
       the legacy monolith's dark-gray `--grey` with no override. This rule
       closes that gap for all paragraphs. */
    .cn-article-prose :global(p) {
        color: var(--on-surface);
    }
    .cn-article-prose :global(p:first-of-type) {
        font-weight: 700;
        color: var(--primary);
    }
    .cn-article-prose :global(h2) {
        font-size: 24px;
        font-weight: 600;
        margin: 40px 0 16px;
        color: var(--on-surface);
    }
    .cn-article-prose :global(p) {
        margin: 0 0 24px;
    }
    .cn-article-prose :global(a) {
        color: var(--accent-blue);
    }
    .cn-article-prose :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: var(--radius-lg);
    }

    .cn-article-trailer {
        margin: 40px 0;
    }
    .cn-article-trailer h2 {
        font-family: var(--font-sans);
        font-size: 24px;
        font-weight: 600;
        margin: 0 0 16px;
        color: var(--on-surface);
    }
    .cn-article-trailer__frame {
        position: relative;
        width: 100%;
        padding-top: 56.25%;
        border-radius: var(--radius-lg);
        overflow: hidden;
        background: #000;
    }
    .cn-article-trailer__frame iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
    }

    .cn-article-prose :global(.cn-podcast-card) {
        margin-top: 48px;
    }

    @media (max-width: 720px) {
        .cn-article-hero {
            /* Content is bottom-anchored (align-items: flex-end), so the
               hero must be TALL enough that even a long (5–6 line) title
               leaves image visible above it — the title then sits low,
               flush against the image's bottom edge, exactly like the
               reference. Earlier short-hero attempts (45vh, 32vh) did the
               opposite: for a long title the content became taller than
               the hero, so the whole image was covered and the title rode
               up to the very top. 56vh keeps a generous image band above
               the title for both short and long headlines. min-height is a
               floor, not a cap, so an unusually long title still grows the
               hero rather than clipping. */
            min-height: 56vh;
            /* The base rule adds 32px padding-bottom on the section itself,
               which sits in the gap between the meta row and the summary on
               top of the content's own padding. Zero it here so the total
               gap is controlled solely by .cn-article-hero__content's
               padding-bottom below (= exactly 15px). */
            padding-bottom: 0;
        }
        .cn-article-hero__content {
            /* Sole contributor to the meta-row → summary gap now that the
               section padding above and the prose padding-top below are both
               zero — makes it exactly 15px, and pulls the bottom-anchored
               title/meta lower, flush toward the image's bottom edge. */
            padding: 0 var(--space-margin-mobile) 15px;
        }
        .cn-article-hero__content h1 {
            font-size: 28px;
        }
        .cn-article-prose {
            padding-top: 0;
        }
    }
</style>
