---
// Homepage — redesigned per `Home.dc.html` (Claude Design export) onto the
// shared design-system components. Content/data architecture is unchanged:
// still reads the `nieuws`/`reviews` collections directly, still keeps
// BaseAdBanner + BasePodcastBanner + BasePodcastBlock (out of scope to
// redesign, kept exactly as components — only their placement/wrapper
// changed). The old embedded About/Contact sections are removed: Contact now
// lives on its own page (`/contact`, owned by the other frontend-developer
// agent on this branch) and — by the same logic, since Home.dc.html has no
// About section either — About moves to `/over-ons` (same agent). Flagged
// explicitly since only Contact's removal was spelled out in the brief.
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/design-system/Header.astro";
import Footer from "../components/design-system/Footer.astro";
import ArticleCard from "../components/design-system/ArticleCard.astro";
import SocialIcons from "../components/design-system/SocialIcons.astro";
import HeroCarousel from "../components/design-system/HeroCarousel.tsx";
import BaseAdBanner from "../components/BaseAdBanner.astro";

import { getCollection } from "astro:content";
import { extractPreview } from "../lib/textPreview";
import { formatCardDate, ratingOutOfTen, slugFromEntryId } from "../lib/format";
import { getNavLinks, FOOTER_COLUMNS, FOOTER_BOTTOM_LEFT, FOOTER_TAGLINE, PARTNER_LABEL } from "../lib/siteNav";

const allNieuwsRaw = (await getCollection("nieuws")).filter((p) => !p.data.draft);
const allNieuws = allNieuwsRaw
  .map((post) => ({
    url: `/nieuws/${slugFromEntryId(post.id)}`,
    data: post.data,
    excerpt: extractPreview(post.body),
  }))
  .sort((a, b) => new Date(b.data.date ?? 0).getTime() - new Date(a.data.date ?? 0).getTime());

const heroPosts = allNieuws.slice(0, 4);
const gridPosts = allNieuws.slice(0, 9);

const allReviewsRaw = (await getCollection("reviews")).filter((p) => !p.data.draft);
const reviewPosts = allReviewsRaw
  .map((post) => ({ url: `/reviews&blogs/${slugFromEntryId(post.id)}`, data: post.data }))
  .sort((a, b) => new Date(b.data.date ?? 0).getTime() - new Date(a.data.date ?? 0).getTime())
  .slice(0, 6);

const heroSlides = heroPosts.map((p) => ({
  image: {
    src: p.data.thumbnail || "/images/Cinematelogotrans.png",
    alt: p.data.title,
  },
  title: p.data.title,
  description: p.data.summary || p.excerpt,
  ctaLabel: "Lees meer",
  ctaHref: p.url,
}));

const canonicalURL = "https://www.cinematen.be/";
---

<html lang="nl">
  <head>
    <BaseHead canonicalURL={canonicalURL} />
  </head>
  <body>
    <div class="cn-page">
      <Header links={getNavLinks("home")} partnerLabel={PARTNER_LABEL}>
        <img slot="logo" src="/images/cinematen-white-horizontal.png" alt="Cinematen.be" width="185" height="28" />
        <img slot="partner-logo" src="/images/kinepolis.png" alt="Kinepolis" width="34" height="34" />
      </Header>

      <HeroCarousel client:load slides={heroSlides} autoplayMs={9000} />

      <section class="cn-home-news">
        <div class="cn-home-news__head">
          <h2>Film &amp; TV nieuws</h2>
        </div>
        <div class="cn-home-news__grid">
          {
            gridPosts.map((p) => (
              // No CategoryBadge here — the real rendered homepage grid
              // (Home.dc.html: `homeNews: NEWS.map(n => ({ ...newsCard(n,
              // 'overlay'), badge: null }))`) explicitly nulls the badge for
              // this section; the category pill is only used elsewhere
              // (e.g. Nieuws listing pages).
              <ArticleCard title={p.data.title} href={p.url} excerpt={p.data.summary || p.excerpt} variant="overlay">
                <img slot="image" src={p.data.thumbnail} alt={p.data.title} loading="lazy" />
                <span slot="meta">{formatCardDate(p.data.date)}</span>
              </ArticleCard>
            ))
          }
        </div>
        <div class="cn-home-news__more">
          <a href="/nieuws/pages/1" class="cn-btn-outline">Meer nieuws</a>
        </div>
      </section>

      {false && (
        <div class="cn-home-adslot">
          <BaseAdBanner />
        </div>
      )}

      <section class="cn-home-podcast" id="podcast">
        <div class="cn-home-podcast__inner">
          <div class="cn-home-podcast__main">
            <span class="cn-eyebrow">Nu te beluisteren</span>
            <h3>Cinematen Podcast</h3>
            <p>
              De wekelijkse podcast over film en TV — elke week bespreken wij het laatste film- en
              serienieuws.
            </p>
            <iframe
              title="Cinematen Podcast op Spotify"
              class="cn-home-podcast__embed"
              src="https://open.spotify.com/embed/show/19O8JqKPSbQWek15vG3sig?utm_source=generator&theme=1"
              width="100%"
              height="152"
              frameborder="0"
              allowfullscreen
              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
              loading="lazy"
            ></iframe>
          </div>
          <div class="cn-home-podcast__side">
            <a
              class="cn-podcast-btn cn-podcast-btn--spotify"
              href="https://open.spotify.com/show/19O8JqKPSbQWek15vG3sig?si=065cd2ef2c294d09"
              target="_blank"
              rel="noopener"
            >
              <img src="/images/Spotify_logo_without_text.svg" alt="" width="22" height="22" loading="lazy" />
              Spotify
            </a>
            <a
              class="cn-podcast-btn cn-podcast-btn--apple"
              href="https://podcasts.apple.com/us/podcast/cinematen/id1674761868"
              target="_blank"
              rel="noopener"
            >
              <img src="/images/apple-podcasts-icon.png" alt="" width="22" height="22" loading="lazy" />
              Apple Podcasts
            </a>
            <a
              class="cn-podcast-btn cn-podcast-btn--rss"
              href="https://anchor.fm/s/db58cba0/podcast/rss"
              target="_blank"
              rel="noopener"
            >
              <img src="/images/rss.svg" alt="" width="22" height="22" loading="lazy" />
              RSS Podcast
            </a>
            <div class="cn-home-podcast__partner">
              <span>Mogelijk gemaakt door</span>
              <a href="https://kinepolis.be" target="_blank" rel="noopener">
                <img src="/images/kinepolis.png" alt="Kinepolis" width="64" height="64" loading="lazy" />
              </a>
            </div>
          </div>
        </div>
      </section>

      <section class="cn-home-reviews">
        <div class="cn-home-reviews__inner">
          <h2>Blogs &amp; Reviews</h2>
          <p>Diepgaande analyses en de nieuwste recensies.</p>
          <div class="cn-home-reviews__grid">
            {
              reviewPosts.map((p) => {
                return (
                  <ArticleCard title={p.data.title} href={p.url} excerpt={p.data.summary ?? undefined} variant="default" rating={ratingOutOfTen(p.data.rating)}>
                    <img slot="image" src={p.data.thumbnail || p.data.poster} alt={p.data.title} loading="lazy" />
                    <span slot="meta">
                      {formatCardDate(p.data.date)}
                      {p.data.schrijver ? ` · ${p.data.schrijver}` : ""}
                    </span>
                  </ArticleCard>
                );
              })
            }
          </div>
          <div class="cn-home-reviews__more">
            <a href="/reviews&blogs/pages/1" class="cn-btn-outline">Meer reviews</a>
          </div>
        </div>
      </section>

      <Footer columns={FOOTER_COLUMNS} bottomLeft={FOOTER_BOTTOM_LEFT}>
        <img slot="logo" src="/images/cinematen-white-horizontal.png" alt="Cinematen.be" width="172" height="26" />
        <Fragment slot="tagline">{FOOTER_TAGLINE}</Fragment>
        <Fragment slot="social-icons">
          <SocialIcons />
        </Fragment>
      </Footer>
    </div>
  </body>
</html>

<style>
  .cn-page {
    min-height: 100dvh;
    background: var(--surface);
    color: var(--on-surface);
  }

  .cn-home-news {
    max-width: var(--container-max);
    margin: -80px auto 0;
    position: relative;
    z-index: 5;
    padding: 0 var(--space-margin-desktop) 48px;
  }
  .cn-home-news__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }
  .cn-home-news__head h2 {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--text-headline-lg-mobile-size);
    color: var(--on-surface);
    margin: 0;
  }
  .cn-home-news__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-gutter);
  }
  .cn-home-news__more {
    display: flex;
    justify-content: center;
    margin-top: 40px;
  }
  .cn-btn-outline {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 15px;
    color: var(--on-surface);
    background: var(--surface-container);
    border: 1px solid var(--outline-variant);
    border-radius: var(--radius-full);
    padding: 14px 32px;
    text-decoration: none;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .cn-btn-outline:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .cn-home-adslot {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-margin-desktop);
  }

  .cn-home-podcast {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 48px var(--space-margin-desktop) 64px;
  }
  .cn-home-podcast__inner {
    background: var(--surface-container);
    border-radius: var(--radius-2xl);
    padding: 48px;
    display: flex;
    gap: 48px;
    align-items: center;
    flex-wrap: wrap;
  }
  .cn-home-podcast__main {
    flex: 2;
    min-width: 340px;
  }
  .cn-eyebrow {
    font-family: var(--font-sans);
    color: var(--accent-blue);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 13px;
  }
  .cn-home-podcast__main h3 {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 36px;
    color: var(--on-surface);
    margin: 8px 0;
  }
  .cn-home-podcast__main p {
    font-family: var(--font-sans);
    color: var(--on-surface-variant);
    margin: 0 0 24px;
    max-width: 65ch;
  }
  .cn-home-podcast__embed {
    border-radius: 12px;
    border: none;
    display: block;
  }
  .cn-home-podcast__side {
    flex: 1;
    min-width: 220px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .cn-podcast-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 20px;
    border-radius: var(--radius-full);
    color: #fff;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }
  .cn-podcast-btn:hover {
    opacity: 0.88;
  }
  .cn-podcast-btn:active {
    transform: translateY(1px);
  }
  .cn-podcast-btn:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  .cn-podcast-btn img {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }
  .cn-podcast-btn--spotify {
    background: #1db954;
  }
  .cn-podcast-btn--apple {
    background: var(--accent-purple);
  }
  .cn-podcast-btn--rss {
    background: #ee802f;
  }
  .cn-home-podcast__partner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
    padding: 20px 0;
    border-top: 1px solid var(--outline-variant);
  }
  .cn-home-podcast__partner span {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--on-surface-variant);
  }
  .cn-home-podcast__partner img {
    display: block;
    border-radius: var(--radius-sm);
  }

  .cn-home-reviews {
    background: var(--surface-container-lowest);
    padding: 64px 0;
    border-top: 1px solid var(--outline-variant);
  }
  .cn-home-reviews__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-margin-desktop);
  }
  .cn-home-reviews__inner h2 {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--text-headline-lg-mobile-size);
    color: var(--on-surface);
    margin: 0 0 8px;
  }
  .cn-home-reviews__inner > p {
    font-family: var(--font-sans);
    color: var(--on-surface-variant);
    margin: 0 0 32px;
  }
  .cn-home-reviews__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  /* Desktop has no "meer" button for this section (matches the original
     design) — only shown on mobile, where the grid is capped to 4 cards. */
  .cn-home-reviews__more {
    display: none;
  }

  @media (max-width: 1024px) {
    .cn-home-news__grid,
    .cn-home-reviews__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 900px) {
    .cn-home-podcast__inner {
      padding: 32px;
    }
  }
  @media (max-width: 720px) {
    .cn-home-news {
      /* Was -48px (an overlap trick that works against the desktop hero,
         which has empty space above its bottom-anchored content) — on
         mobile the hero's content sits right at its bottom edge (button
         included), so pulling the news section up by nearly as much as the
         hero's own bottom padding visually collided the "Film & TV nieuws"
         heading with the "Lees meer" button. */
      margin-top: 24px;
      padding: 0 var(--space-margin-mobile) 32px;
    }
    .cn-home-adslot,
    .cn-home-podcast,
    .cn-home-reviews__inner {
      padding-left: var(--space-margin-mobile);
      padding-right: var(--space-margin-mobile);
    }
    .cn-home-news__grid,
    .cn-home-reviews__grid {
      grid-template-columns: 1fr;
    }
    /* Cap both homepage grids to 4 cards on mobile — the rest exist in the
       DOM (desktop still shows 9/6) but are hidden past the 4th so mobile
       gets a short list plus a "meer" link instead of a long scroll. */
    .cn-home-news__grid > :global(:nth-child(n + 5)),
    .cn-home-reviews__grid > :global(:nth-child(n + 5)) {
      display: none;
    }
    .cn-home-reviews__more {
      display: flex;
      justify-content: center;
      margin-top: 32px;
    }
    /* Spotify's embed widget picks compact-horizontal vs large-vertical
       layout based on the iframe's own rendered height, not just width —
       the desktop height="152" attribute locks it into compact-horizontal,
       which doesn't have room at mobile card widths and overflows (title/
       buttons run past the edge). A taller height on mobile makes Spotify's
       own script switch to its large vertical card layout instead. */
    .cn-home-podcast__embed {
      height: 352px;
    }
    /* .cn-home-podcast__main's min-width: 340px (set for the desktop 2-up
       layout) is wider than the actual available space once the card's own
       padding + page margin are subtracted on a narrow phone, forcing an
       overflow (text pushed past the edge). Just zeroing min-width isn't
       enough on its own either: without it, .main and .side can end up
       fighting for space on the same wrapped row instead of each getting
       their own — .side collapsed to ~72px and squashed its buttons into
       circles with the labels overflowing outside them. flex-basis: 100%
       forces each onto its own full-width row unconditionally. */
    .cn-home-podcast__main,
    .cn-home-podcast__side {
      min-width: 0;
      flex-basis: 100%;
    }
    /* Same auto-width-from-aspect-ratio squashing bug as the header logo
       under flex-basis: auto — see Header.astro's mobile block. Explicit
       width sidesteps it. */
    .cn-home-podcast__partner img {
      width: 64px;
      flex-shrink: 0;
    }
  }
</style>
