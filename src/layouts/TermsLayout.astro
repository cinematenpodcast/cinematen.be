---
// TermsLayout — shared chrome for the legal pages (privacypolicy.md,
// termsofservice.md, cookiebeleid.md). Restyled onto the design-system
// Header/Footer + typography tokens; markdown body content (h2/p/ul/strong)
// is styled via scoped :global() descendant selectors since the rendered
// markdown lands inside <slot /> without its own component boundary.
import BaseHead from "../components/BaseHead.astro";
import BaseScript from "../components/BaseScript.astro";
import Header from "../components/design-system/Header.astro";
import Footer from "../components/design-system/Footer.astro";
import SocialIcons from "../components/design-system/SocialIcons.astro";
import {
  getNavLinks,
  FOOTER_COLUMNS,
  FOOTER_BOTTOM_LEFT,
  FOOTER_TAGLINE,
  PARTNER_LABEL,
} from "../lib/siteNav";

const { frontmatter } = Astro.props;
const canonicalURL = `https://www.cinematen.be${Astro.url.pathname}`;
const navLinks = getNavLinks(null);
---

<html lang="nl">
  <head>
    <BaseHead
      title={frontmatter.title}
      description={frontmatter.summary}
      canonicalURL={canonicalURL}
    />
  </head>
  <body class="cn-legal-body">
    <Header links={navLinks} partnerLabel={PARTNER_LABEL}>
      <img
        slot="logo"
        src="/images/LogoCleanSmaller.png"
        alt="Cinematen"
        width="26"
        height="28"
        style="height:28px;width:auto;"
      />
      <img
        slot="partner-logo"
        src="/images/kinepolis.png"
        alt="Kinepolis Antwerpen"
        width="28"
        height="28"
        style="height:28px;width:auto;display:block;"
      />
    </Header>

    <main class="cn-legal">
      <h1 class="cn-legal__title">{frontmatter.title}</h1>
      {
        frontmatter.lastUpdated && (
          <p class="cn-legal__updated">
            Laatst bijgewerkt: {frontmatter.lastUpdated}
          </p>
        )
      }
      <div class="cn-legal__body">
        <slot />
      </div>
    </main>

    <Footer columns={FOOTER_COLUMNS} bottomLeft={FOOTER_BOTTOM_LEFT}>
      <img
        slot="logo"
        src="/images/LogoCleanSmaller.png"
        alt="Cinematen"
        width="37"
        height="40"
        style="height:40px;width:auto;"
      />
      <Fragment slot="tagline">{FOOTER_TAGLINE}</Fragment>
      <Fragment slot="social-icons"><SocialIcons /></Fragment>
    </Footer>

    <BaseScript />

    <style>
      .cn-legal-body {
        margin: 0;
        background: var(--surface);
      }
      .cn-legal {
        max-width: 760px;
        margin: 0 auto;
        padding: 64px var(--space-margin-desktop) 80px;
      }
      .cn-legal__title {
        font-family: var(--font-sans);
        font-weight: var(--font-headline-weight);
        font-size: 44px;
        color: var(--on-surface);
        margin: 0 0 8px;
      }
      .cn-legal__updated {
        font-family: var(--font-sans);
        font-size: 14px;
        color: var(--on-surface-variant);
        margin: 0 0 40px;
      }
      .cn-legal__body :global(h2) {
        font-family: var(--font-sans);
        font-size: 22px;
        font-weight: 700;
        margin: 36px 0 12px;
        color: var(--on-surface);
      }
      .cn-legal__body :global(p),
      .cn-legal__body :global(li) {
        font-family: var(--font-sans);
        font-size: 16px;
        line-height: 1.7;
        color: var(--on-surface-variant);
        margin: 0 0 14px;
      }
      .cn-legal__body :global(ul) {
        margin: 0 0 14px;
        padding-left: 20px;
      }
      .cn-legal__body :global(strong) {
        color: var(--on-surface);
      }
      .cn-legal__body :global(a) {
        color: var(--accent-blue);
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      .cn-legal__body :global(a:hover) {
        color: var(--primary);
      }
      .cn-legal__body :global(a:focus-visible) {
        outline: 2px solid var(--primary);
        outline-offset: 2px;
      }
      .cn-legal__body :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 0 0 24px;
        font-size: 14px;
      }
      .cn-legal__body :global(th),
      .cn-legal__body :global(td) {
        text-align: left;
        padding: 10px 12px;
        border-bottom: 1px solid var(--outline-variant);
        color: var(--on-surface-variant);
      }
      .cn-legal__body :global(th) {
        color: var(--on-surface);
        font-weight: 700;
      }

      @media (max-width: 640px) {
        .cn-legal {
          padding: 48px var(--space-margin-mobile) 64px;
        }
        .cn-legal__title {
          font-size: 32px;
        }
      }
    </style>
  </body>
</html>
