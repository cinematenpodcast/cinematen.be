---
// Review/blog detail — redesigned per `Review.dc.html`.
// Wrapped by src/pages/reviews&blogs/[...slug].astro (untouched, still
// passes `frontmatter` + slotted MDX `<Content />`). Same SEO/schema.org
// pipeline and component inclusions as before (RandomReviews) — only the
// visual chrome around the article body changed. BasePodcastBanner was
// replaced with the shared PodcastCard component (real Spotify show embed)
// and a trailer embed was added, matching NieuwsLayout.astro.
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/design-system/Header.astro";
import Footer from "../components/design-system/Footer.astro";
import SocialIcons from "../components/design-system/SocialIcons.astro";
import CategoryBadge from "../components/design-system/CategoryBadge.astro";
import PodcastCard from "../components/design-system/PodcastCard.astro";
import RandomReviews from "../components/RandomReviews.astro";
import { formatCardDate, formatDateISO, ratingOutOfTen } from "../lib/format";
import { getNavLinks, FOOTER_COLUMNS, FOOTER_BOTTOM_LEFT, FOOTER_TAGLINE, PARTNER_LABEL } from "../lib/siteNav";

const { frontmatter } = Astro.props;

// Generate canonical URL for this review
const canonicalURL = `https://www.cinematen.be${Astro.url.pathname}`;

// Generate title and description for this review
const reviewTitle = `${frontmatter.title} - ${frontmatter.soort || 'Review'}`;
const soortLower = (frontmatter.soort || "").toLowerCase();
const itemReviewedType = soortLower.includes("serie") || soortLower.includes("tv") ? "TVSeries" : "Movie";
const reviewDescription = `Lees onze ${frontmatter.soort ? frontmatter.soort.toLowerCase() : 'review'} van ${frontmatter.title}. Bekijk onze beoordeling en ontdek of deze ${frontmatter.soort ? frontmatter.soort.toLowerCase() : 'content'} de moeite waard is.`;

const displayDate = formatCardDate(frontmatter.date);
// `rating` is stored on a 0–10 scale (migrated from the original 0–5-in-
// 0.5-steps scale — see scripts/organize-content.mjs) — the schema.org
// Review markup below keeps that native scale (bestRating: 10).
const ratingLabel = ratingOutOfTen(frontmatter.rating);
// `trailer` is a plain YouTube video ID in frontmatter (e.g. "f_bKjZeJBBI"),
// not a full URL — see src/content/config.ts. youtube-nocookie.com avoids
// setting third-party cookies until the visitor actually plays the video.
const trailerSrc = frontmatter.trailer ? `https://www.youtube-nocookie.com/embed/${frontmatter.trailer}` : null;
---

<html lang="nl">
    <head>
        <BaseHead
            canonicalURL={canonicalURL}
            title={reviewTitle}
            description={reviewDescription}
            publishedDate={frontmatter.date}
            modifiedDate={frontmatter.date}
            articleType="article"
            author={frontmatter.schrijver}
            image={frontmatter.poster}
        />
        {frontmatter.rating && frontmatter.rating > 0 && (
        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "Review",
          "name": reviewTitle,
          "description": reviewDescription,
          "url": canonicalURL,
          ...(frontmatter.date && { "datePublished": new Date(frontmatter.date).toISOString() }),
          "author": {
            "@type": "Person",
            "name": frontmatter.schrijver || "Cinematen",
            "url": "https://www.cinematen.be/#over-ons",
            "sameAs": ["https://www.instagram.com/cinematen_podcast"]
          },
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": frontmatter.rating,
            "bestRating": 10,
            "worstRating": 1
          },
          "itemReviewed": {
            "@type": itemReviewedType,
            "name": frontmatter.title,
            ...(frontmatter.poster && { "image": frontmatter.poster.startsWith('http') ? frontmatter.poster : `https://www.cinematen.be${encodeURI(frontmatter.poster)}` })
          },
          "publisher": {
            "@type": "Organization",
            "name": "Cinematen",
            "logo": {
              "@type": "ImageObject",
              "url": "https://www.cinematen.be/images/Cinematelogotrans.png"
            }
          }
        })}></script>
        )}
        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.cinematen.be/" },
            { "@type": "ListItem", "position": 2, "name": "Reviews & Blogs", "item": "https://www.cinematen.be/reviews&blogs/" },
            { "@type": "ListItem", "position": 3, "name": reviewTitle, "item": canonicalURL }
          ]
        })}></script>
    </head>
    <body>
        <div class="cn-page">
            <Header links={getNavLinks("reviews")} partnerLabel={PARTNER_LABEL}>
                <img slot="logo" src="/images/cinematen-white-horizontal.png" alt="Cinematen.be" width="185" height="28" />
                <img slot="partner-logo" src="/images/kinepolis.png" alt="Kinepolis" width="34" height="34" />
            </Header>

            <main>
                <section class="cn-review-hero">
                    <div class="cn-review-hero__media" aria-hidden="true">
                        <img src={frontmatter.thumbnail || frontmatter.poster} alt="" loading="eager" decoding="sync" fetchpriority="high" />
                        <div class="cn-review-hero__scrim"></div>
                    </div>
                    <div class="cn-review-hero__content">
                        <div class="cn-review-hero__row">
                            <div class="cn-review-hero__text">
                                <CategoryBadge label="REVIEW" tone={soortLower === "tv" ? "tv" : "film"} />
                                <h1>{frontmatter.title}</h1>
                                <div class="cn-review-hero__meta">
                                    {displayDate && (
                                        <span class="cn-review-hero__date" data-pagefind-meta={`date:${formatDateISO(frontmatter.date)}`}>
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                                <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                                <line x1="3" y1="10" x2="21" y2="10"></line>
                                            </svg>
                                            {displayDate}
                                        </span>
                                    )}
                                    {frontmatter.schrijver && (
                                        <span class="cn-review-hero__author">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                                <circle cx="12" cy="7" r="4"></circle>
                                            </svg>
                                            Door {frontmatter.schrijver}
                                        </span>
                                    )}
                                </div>
                            </div>
                            {frontmatter.poster && (
                                <div class="cn-review-hero__poster-wrap">
                                    <img class="cn-review-hero__poster" src={frontmatter.poster} alt={`${frontmatter.title} poster`} />
                                    {ratingLabel && (
                                        <div class="cn-review-hero__rating">
                                            <span class="cn-review-hero__rating-num">{ratingLabel}</span>
                                            <span class="cn-review-hero__rating-denom">/10</span>
                                        </div>
                                    )}
                                </div>
                            )}
                        </div>
                    </div>
                </section>

                <article class="cn-article-prose">
                    {frontmatter.summary && <p>{frontmatter.summary}</p>}
                    <slot />

                    {trailerSrc && (
                        <div class="cn-article-trailer">
                            <h2>Bekijk de trailer</h2>
                            <div class="cn-article-trailer__frame">
                                <iframe
                                    src={trailerSrc}
                                    title="Trailer"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                    allowfullscreen
                                    loading="lazy"
                                ></iframe>
                            </div>
                        </div>
                    )}

                    <PodcastCard />
                </article>

                <RandomReviews currentSlug={frontmatter.slug} />
            </main>

            <Footer columns={FOOTER_COLUMNS} bottomLeft={FOOTER_BOTTOM_LEFT}>
                <img slot="logo" src="/images/cinematen-white-horizontal.png" alt="Cinematen.be" width="172" height="26" />
                <Fragment slot="tagline">{FOOTER_TAGLINE}</Fragment>
                <Fragment slot="social-icons">
                    <SocialIcons />
                </Fragment>
            </Footer>
        </div>
    </body>
</html>

<style>
    .cn-page {
        min-height: 100dvh;
        background: var(--surface);
        color: var(--on-surface);
    }

    .cn-review-hero {
        position: relative;
        width: 100%;
        min-height: 66vh;
        display: flex;
        align-items: flex-end;
        padding-bottom: 48px;
    }
    .cn-review-hero__media {
        position: absolute;
        inset: 0;
        z-index: 0;
    }
    .cn-review-hero__media img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .cn-review-hero__scrim {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(13, 23, 48, 0.95) 0%, rgba(13, 23, 48, 0.3) 55%, transparent 100%);
    }
    .cn-review-hero__content {
        position: relative;
        z-index: 1;
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 0 var(--space-margin-desktop) 48px;
        width: 100%;
        box-sizing: border-box;
    }
    .cn-review-hero__row {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 32px;
        flex-wrap: wrap;
    }
    .cn-review-hero__text {
        flex: 0 1 400px;
        min-width: 280px;
    }
    .cn-review-hero__text h1 {
        font-family: var(--font-sans);
        font-weight: 800;
        letter-spacing: -0.01em;
        font-size: 52px;
        line-height: 1.05;
        color: var(--on-surface);
        margin: 16px 0 24px;
    }
    .cn-review-hero__meta {
        display: flex;
        gap: 16px;
        align-items: center;
        flex-wrap: wrap;
        font-family: var(--font-sans);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--on-surface-variant);
    }
    .cn-review-hero__date,
    .cn-review-hero__author {
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .cn-review-hero__author {
        background: var(--surface-container-high);
        color: var(--on-surface);
        border-radius: var(--radius-full);
        padding: 4px 12px;
    }
    .cn-review-hero__poster-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 19px;
        flex-shrink: 0;
    }
    .cn-review-hero__poster {
        width: 260px;
        max-width: 40vw;
        aspect-ratio: 2 / 3;
        object-fit: cover;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
        border: 1px solid rgba(255, 255, 255, 0.14);
        display: block;
    }
    .cn-review-hero__rating {
        display: flex;
        align-items: baseline;
        gap: 6px;
        background: rgba(10, 17, 40, 0.72);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: var(--radius-lg);
        padding: 9px 22px;
        line-height: 1;
    }
    .cn-review-hero__rating-num {
        font-family: var(--font-sans);
        font-weight: 800;
        font-size: 26px;
        color: var(--on-surface);
    }
    .cn-review-hero__rating-denom {
        font-family: var(--font-sans);
        font-weight: 600;
        font-size: 15px;
        color: var(--on-surface-variant);
    }

    .cn-article-prose {
        max-width: 900px;
        margin: 0 auto;
        padding: 48px var(--space-margin-mobile) 64px;
        font-family: var(--font-sans);
        font-size: 18px;
        line-height: 1.6;
        color: var(--on-surface);
    }
    /* public/style.css ships a global `p { color: var(--grey); ... }` rule
       (a plain type selector) that directly targets every <p> the MDX body
       renders. A directly-matching rule always wins over an inherited value
       regardless of specificity, so `.cn-article-prose { color: on-surface }`
       above — which only sets color on the ancestor, never on `p` itself —
       never actually reaches any paragraph. `:first-of-type` below happens to
       look fine only because its own selector also targets `p` directly and
       out-specifies the global rule; every later paragraph fell through to
       the legacy monolith's dark-gray `--grey` with no override. This rule
       closes that gap for all paragraphs. */
    .cn-article-prose :global(p) {
        color: var(--on-surface);
    }
    .cn-article-prose :global(p:first-of-type) {
        font-weight: 700;
        color: var(--primary);
    }
    .cn-article-prose :global(h2),
    .cn-article-prose :global(h3) {
        font-size: 24px;
        font-weight: 600;
        margin: 40px 0 16px;
        color: var(--on-surface);
    }
    .cn-article-prose :global(p) {
        margin: 0 0 24px;
    }
    .cn-article-prose :global(a) {
        color: var(--accent-blue);
    }
    .cn-article-prose :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: var(--radius-lg);
    }

    .cn-article-trailer {
        margin: 40px 0;
    }
    .cn-article-trailer h2 {
        font-family: var(--font-sans);
        font-size: 24px;
        font-weight: 600;
        margin: 0 0 16px;
        color: var(--on-surface);
    }
    .cn-article-trailer__frame {
        position: relative;
        width: 100%;
        padding-top: 56.25%;
        border-radius: var(--radius-lg);
        overflow: hidden;
        background: #000;
    }
    .cn-article-trailer__frame iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
    }

    .cn-article-prose :global(.cn-podcast-card) {
        margin-top: 48px;
    }

    @media (max-width: 720px) {
        .cn-review-hero {
            /* Same as the nieuws hero: zero the section's own padding-bottom
               so the meta-row → summary gap is controlled solely by the
               content padding below (kept tight, matching the reference). */
            padding-bottom: 0;
        }
        .cn-review-hero__content {
            padding: 32px var(--space-margin-mobile) 15px;
        }
        /* Reference mobile layout is a vertical stack, poster-first:
           poster (centered) → score → REVIEW badge → title → meta.
           The DOM order is text-then-poster (for the desktop side-by-side),
           so column-reverse flips it to poster-then-text without touching
           the markup. */
        .cn-review-hero__row {
            flex-direction: column-reverse;
            align-items: stretch;
            gap: 20px;
        }
        .cn-review-hero__text {
            flex: none;
            min-width: 0;
        }
        .cn-review-hero__text h1 {
            font-size: 28px;
            margin: 12px 0 12px;
        }
        /* poster-wrap already centers its own children (poster + score),
           so stretching it full-width leaves the poster centered. */
        .cn-review-hero__poster {
            width: 220px;
            max-width: 62vw;
        }
        .cn-article-prose {
            padding-top: 0;
        }
    }
</style>
