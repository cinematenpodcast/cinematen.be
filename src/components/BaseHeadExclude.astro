---
// New design-system tokens + self-hosted fonts, same import BaseHead.astro
// carries — this head partial (used on noindex pagination/tag/search pages)
// was missing it, which would starve those redesigned pages of the CSS
// custom properties the new components render with.
import "../styles/design-system/index.css";
---
<meta charset="utf-8" />
<meta content="width=device-width, initial-scale=1" name="viewport" />
<meta name="pagefind-noindex" content="true" />
<meta name="robots" content="noindex, follow" />
<meta name="google-site-verification" content="Ue-nOWKl8b37dpA_44eTIqresdKx1GF8BO1BEfSXwg4" />
<title>Cinematen.be</title>
<meta
    content="Cinematen.be houdt je vinger aan de pols met het meest actuele nieuws uit de film- en seriewereld, inclusief de laatste ontwikkelingen uit Hollywood. Ontdek previews, trailers, recensies en exclusieve interviews. Blijf op de hoogte van alles wat actueel is op het grote en kleine scherm."
    name="description"
/>

<!-- Open Graph / Twitter -->
<meta content="Cinematen.be" property="og:title" />
<meta
    content="Cinematen.be houdt je vinger aan de pols met het meest actuele nieuws uit de film- en seriewereld, inclusief de laatste ontwikkelingen uit Hollywood. Ontdek previews, trailers, recensies en exclusieve interviews. Blijf op de hoogte van alles wat actueel is op het grote en kleine scherm."
    property="og:description"
/>
<meta content="https://www.cinematen.be/images/Cinematelogotrans.png" property="og:image" />
<meta content="website" property="og:type" />
<meta content="Cinematen.be" property="twitter:title" />
<meta
    content="Cinematen.be houdt je vinger aan de pols met het meest actuele nieuws uit de film- en seriewereld, inclusief de laatste ontwikkelingen uit Hollywood. Ontdek previews, trailers, recensies en exclusieve interviews. Blijf op de hoogte van alles wat actueel is op het grote en kleine scherm."
    property="twitter:description"
/>
<meta content="/images/Cinematelogotrans.png" property="twitter:image" />
<meta content="summary_large_image" name="twitter:card" />

<!-- Favicon -->
<link href="/images/favicon.ico" rel="shortcut icon" type="image/x-icon" />
<link href="/images/favicon-512.png" rel="icon" type="image/png" sizes="512x512" />
<link href="/images/webclip.png" rel="apple-touch-icon" />

<!-- Fonts (Rubik / Rubik Mono One) are self-hosted via @font-face in
     src/styles/design-system/fonts.css — no Google Fonts origin needed.
     (This used to also load a Google Fonts stylesheet via the media="print"
     + onload="this.media='all'" deferred-load trick, but that inline onload
     handler was always blocked by CSP script-src — dead code producing a
     console violation on every page.) -->

<!-- Critical CSS (is:inline prevents Astro scoping) -->
<style is:inline>
    * {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }
</style>

<!-- Main stylesheet -->
<link href="/style.css" rel="stylesheet" />

<!-- Webflow + Google Analytics (external; CSP-safe) -->
<script is:inline defer src="/scripts/init.js"></script>
