---
// Restyled onto the shared design system (was a standalone light-theme card
// row, clashing with the redesigned dark article/review pages). Same
// query/shuffle logic as before — only the markup/CSS changed.
import { getCollection } from "astro:content";
import ArticleCard from "./design-system/ArticleCard.astro";
import { formatCardDate, ratingOutOfTen, slugFromEntryId } from "../lib/format";

const { currentSlug } = Astro.props;

// Alle reviews ophalen
const allReviewsRaw = await getCollection("reviews");
// `slug` can't live in the collection schema (Astro forbids it for
// `type: "content"` collections) — Astro's own top-level `post.slug`
// (derived from the frontmatter `slug:` override, see src/content/config.ts)
// is used instead of the old `post.data.slug`/`post.frontmatter.slug`.
const allReviews = allReviewsRaw
  .filter(post => !post.data.draft)
  .map(post => ({
    url: `/reviews&blogs/${slugFromEntryId(post.id)}`,
    data: post.data,
    slug: post.slug,
  }));

// Filter de huidige review eruit
const filteredReviews = allReviews.filter(post => post.slug !== currentSlug);

// Shuffle functie
function shuffle(array) {
  let currentIndex = array.length, randomIndex;
  while (currentIndex !== 0) {
    randomIndex = Math.floor(Math.random() * currentIndex);
    currentIndex--;
    [array[currentIndex], array[randomIndex]] = [array[randomIndex], array[currentIndex]];
  }
  return array;
}

// Kies 3 random reviews
const randomReviews = shuffle(filteredReviews).slice(0, 3);
---

{randomReviews.length > 0 && (
  <section class="cn-random-reviews">
    <div class="cn-random-reviews__inner">
      <h2>Misschien ben je ook wel geïnteresseerd in&hellip;</h2>
      <div class="cn-random-reviews__grid">
        {randomReviews.map((post) => {
          return (
            <ArticleCard title={post.data.title} href={post.url} excerpt={post.data.summary ?? undefined} rating={ratingOutOfTen(post.data.rating)}>
              <img slot="image" src={post.data.thumbnail || post.data.poster} alt={post.data.title} loading="lazy" />
              <span slot="meta">{formatCardDate(post.data.date)}</span>
            </ArticleCard>
          );
        })}
      </div>
    </div>
  </section>
)}

<style>
  .cn-random-reviews {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-margin-desktop) 32px;
  }
  .cn-random-reviews__inner h2 {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 24px;
    color: var(--on-surface);
    text-align: center;
    margin: 0 0 32px;
  }
  .cn-random-reviews__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-gutter);
  }
  @media (max-width: 900px) {
    .cn-random-reviews {
      padding: 0 var(--space-margin-mobile) 24px;
    }
    .cn-random-reviews__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
