---
// Restyled onto the shared design system (was a standalone light-theme card
// grid, clashing with the redesigned dark article page). Same query/data
// logic as before — only the markup/CSS changed, to match Artikel.dc.html's
// "Misschien ook interessant" section.
import { getCollection } from "astro:content";
import ArticleCard from "./design-system/ArticleCard.astro";
import CategoryBadge from "./design-system/CategoryBadge.astro";
import { formatCardDate } from "../lib/format";

const { currentSlug, soort } = Astro.props;

function getCleanId(id) {
  return id ? id.replace(/\.mdx$/, '') : '';
}

const allNieuws = await getCollection("nieuws");
const related = allNieuws
  // `slug` can't live in the collection schema (Astro forbids it for
  // `type: "content"` collections) — Astro's own top-level `p.slug`
  // (derived from the frontmatter `slug:` override, see src/content/config.ts)
  // is used instead of the old `p.data.slug`.
  .filter(p => !p.data.draft && p.slug !== currentSlug && p.data.soort === soort)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

{related.length > 0 && (
  <section class="cn-related">
    <div class="cn-related__inner">
      <h2>Misschien ook interessant</h2>
      <div class="cn-related__grid">
        {related.map(p => (
          <ArticleCard title={p.data.title} href={`/nieuws/${getCleanId(p.id)}`} excerpt={p.data.summary}>
            {p.data.thumbnail && <img slot="image" src={p.data.thumbnail} alt={p.data.title} loading="lazy" />}
            {p.data.soort && (
              <CategoryBadge slot="badge" label={`${p.data.soort} nieuws`} tone={p.data.soort.toLowerCase() === "tv" ? "tv" : "film"} />
            )}
            <span slot="meta">{formatCardDate(p.data.date)}</span>
          </ArticleCard>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .cn-related {
    background: var(--surface-container-lowest);
    padding: 64px 0;
    border-top: 1px solid var(--outline-variant);
  }
  .cn-related__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-margin-desktop);
  }
  .cn-related__inner h2 {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 30px;
    color: var(--on-surface);
    margin: 0 0 32px;
  }
  .cn-related__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-gutter);
  }
  @media (max-width: 900px) {
    .cn-related__inner {
      padding: 0 var(--space-margin-mobile);
    }
    .cn-related__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
