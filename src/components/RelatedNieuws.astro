---
import { getCollection } from "astro:content";
const { currentSlug, soort } = Astro.props;

function getCleanId(id) {
  return id ? id.replace(/\.mdx$/, '') : '';
}

const allNieuws = await getCollection("nieuws");
const related = allNieuws
  // `slug` can't live in the collection schema (Astro forbids it for
  // `type: "content"` collections) — Astro's own top-level `p.slug`
  // (derived from the frontmatter `slug:` override, see src/content/config.ts)
  // is used instead of the old `p.data.slug`.
  .filter(p => !p.data.draft && p.slug !== currentSlug && p.data.soort === soort)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

{related.length > 0 && (
  <section class="related-nieuws">
    <h2 class="related-nieuws-title">Meer {soort} nieuws</h2>
    <div class="related-nieuws-row">
      {related.map(p => (
        <a href={`/nieuws/${getCleanId(p.id)}`} class="related-nieuws-card">
          {p.data.thumbnail && <img src={p.data.thumbnail} alt={p.data.title} class="related-nieuws-img" />}
          <div class="related-nieuws-info">
            <p class="related-nieuws-cat">{p.data.soort}</p>
            <h3 class="related-nieuws-ttl">{p.data.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
.related-nieuws { padding: 2rem 1rem; max-width: 1200px; margin: 0 auto; }
.related-nieuws-title { text-align: center; margin-bottom: 1.5rem; color: #2d3370; font-size: 1.5rem; }
.related-nieuws-row { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; }
.related-nieuws-card { flex: 1 1 250px; max-width: 320px; background: #fff; border-radius: 12px; box-shadow: 0 22px 34px rgba(0, 0, 0, .06); overflow: hidden; text-decoration: none; color: inherit; display: block; transition: transform 0.18s; }
.related-nieuws-card:hover { transform: translateY(-2px); }
.related-nieuws-img { width: 100%; height: 160px; object-fit: cover; display: block; }
.related-nieuws-info { padding: 1rem; }
.related-nieuws-cat { font-size: 0.8rem; color: #6c5ce7; margin: 0 0 0.5rem; }
.related-nieuws-ttl { font-size: 1rem; margin: 0; line-height: 1.4; color: #2d3370; }
</style>
