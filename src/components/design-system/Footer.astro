---
/**
 * Footer — brand/tagline column + social icons, N link columns, legal row.
 *
 * Ported from _ds_bundle.js `components/layout/Footer.jsx`.
 * Replaces: BaseFooter.astro.
 *
 * Note: the source bundle fixed the brand column and tagline block to exact
 * pixel dimensions (width: 629px; tagline 599x149px) that read as an
 * artifact of the design tool's own canvas rather than an intentional
 * design token (nothing in tokens/spacing.css corresponds to them, and they
 * broke the grid on any viewport narrower than ~950px). This port replaces
 * them with fluid sizing — the 1.6fr/1fr grid split already controls the
 * column proportion, and a max-width: 60ch caps tagline line length for
 * readability instead. Flagging this explicitly in case the fixed widths
 * were actually load-bearing for a specific canvas export.
 * Also added a mobile stacking breakpoint (source had none — the grid would
 * overflow on narrow viewports).
 *
 * Props:
 *   columns       Array<{ heading: string; links: Array<{ label: string; href: string }> }>
 *   bottomLeft?   e.g. "© 2026 Cinematen. Alle rechten voorbehouden."
 *   bottomRight?  e.g. a secondary legal line or link row (plain text/string)
 * Slots:
 *   logo          (required) — brand mark
 *   tagline       (optional) — short brand description
 *   social-icons  (optional) — row of social link/icon nodes
 */
interface FooterColumn {
  heading: string;
  links: { label: string; href: string }[];
}
interface Props {
  columns: FooterColumn[];
  bottomLeft?: string;
  bottomRight?: string;
}

const { columns, bottomLeft, bottomRight } = Astro.props;
const hasTagline = Astro.slots.has("tagline");
const hasSocial = Astro.slots.has("social-icons");
---

<footer class="cn-footer">
  <div class="cn-footer__inner">
    <div class="cn-footer__top">
      <div class="cn-footer__brand">
        <a href="/" class="cn-footer__logo-link"><slot name="logo" /></a>
        {hasTagline && (
          <div class="cn-footer__tagline">
            <slot name="tagline" />
          </div>
        )}
        {hasSocial && (
          <div class="cn-footer__social">
            <slot name="social-icons" />
          </div>
        )}
      </div>
      <div class="cn-footer__columns" style={`--cn-footer-col-count: ${columns.length}`}>
        {columns.map((col) => (
          <div class="cn-footer__column">
            <h4 class="cn-footer__heading">{col.heading}</h4>
            <ul class="cn-footer__links">
              {col.links.map((l) => (
                <li>
                  <a href={l.href} class="cn-footer__link">
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
    <div class="cn-footer__bottom">
      {bottomLeft && <p>{bottomLeft}</p>}
      {bottomRight && <p>{bottomRight}</p>}
    </div>
  </div>
</footer>

<style>
  .cn-footer {
    background: var(--surface-container-lowest);
    border-top: 1px solid var(--outline-variant);
    padding: 64px 0 32px;
  }
  .cn-footer__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-margin-desktop);
  }
  .cn-footer__top {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 64px;
    margin-bottom: 48px;
  }
  .cn-footer__logo-link {
    display: inline-flex;
  }
  .cn-footer__brand :global(img),
  .cn-footer__brand :global(svg) {
    display: block;
  }
  .cn-footer__tagline {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--on-surface-variant);
    line-height: 1.6;
    margin: 24px 0;
    max-width: 60ch;
  }
  .cn-footer__social {
    display: flex;
    gap: 16px;
  }
  .cn-footer__columns {
    display: grid;
    grid-template-columns: repeat(var(--cn-footer-col-count, 1), 1fr);
    gap: 24px;
  }
  .cn-footer__heading {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--on-surface);
    margin: 0 0 16px;
  }
  .cn-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .cn-footer__link {
    color: var(--on-surface-variant);
    text-decoration: none;
    font-size: 14px;
    font-family: var(--font-sans);
  }
  .cn-footer__link:hover {
    color: var(--primary);
  }
  .cn-footer__link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }
  .cn-footer__bottom {
    border-top: 1px solid var(--outline-variant);
    padding-top: 32px;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: 10px;
    color: #fff;
  }
  .cn-footer__bottom p {
    margin: 0;
    /* public/style.css ships a global `p { color: var(--grey) }` rule that
       directly targets this <p> — a directly-matching rule always wins
       over the inherited color from .cn-footer__bottom, regardless of
       specificity, so it must be set here explicitly too. */
    color: #fff;
  }

  @media (max-width: 768px) {
    .cn-footer__top {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .cn-footer__columns {
      grid-template-columns: repeat(2, 1fr);
    }
    /* Same auto-width-from-aspect-ratio squashing bug as the header logo
       under flex-basis: auto (here via inline-flex) — see Header.astro's
       mobile block. Explicit width sidesteps it. */
    .cn-footer__brand :global(img) {
      width: 172px;
    }
  }
</style>
