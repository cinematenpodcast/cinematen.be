---
/**
 * SocialIcons — Facebook/Instagram icon pair for Footer's `social-icons`
 * slot.
 *
 * Plain outline-style glyphs (`color: var(--on-surface-variant)`, no filled
 * background pill), matching the rest of the footer's icon treatment.
 */
---

<a
  href="https://www.facebook.com/cinematenpodcast/"
  target="_blank"
  rel="noopener"
  class="cn-social-link"
  aria-label="Cinematen op Facebook"
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
    <path
      d="M13.5 22v-8.5H16l.5-3.5h-3V7.8c0-1 .28-1.7 1.73-1.7H16.6V3.14C16.3 3.1 15.28 3 14.1 3c-2.44 0-4.1 1.49-4.1 4.22V10H7.5v3.5H10V22h3.5Z"
    ></path>
  </svg>
</a>
<a
  href="https://www.instagram.com/cinematen_podcast"
  target="_blank"
  rel="noopener"
  class="cn-social-link"
  aria-label="Cinematen op Instagram"
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
    <path
      d="M12 2.2c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.21 15.58 2.2 15.2 2.2 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.21 8.8 2.2 12 2.2Zm0 1.8c-3.15 0-3.5.01-4.74.07-.9.04-1.38.19-1.7.32-.43.16-.74.36-1.06.68-.32.32-.52.63-.68 1.06-.13.32-.28.8-.32 1.7C3.21 8.5 3.2 8.85 3.2 12s.01 3.5.07 4.74c.04.9.19 1.38.32 1.7.16.43.36.74.68 1.06.32.32.63.52 1.06.68.32.13.8.28 1.7.32 1.24.06 1.59.07 4.74.07s3.5-.01 4.74-.07c.9-.04 1.38-.19 1.7-.32.43-.16.74-.36 1.06-.68.32-.32.52-.63.68-1.06.13-.32.28-.8.32-1.7.06-1.24.07-1.59.07-4.74s-.01-3.5-.07-4.74c-.04-.9-.19-1.38-.32-1.7a2.85 2.85 0 0 0-.68-1.06 2.85 2.85 0 0 0-1.06-.68c-.32-.13-.8-.28-1.7-.32C15.5 4.01 15.15 4 12 4Zm0 3.06A4.94 4.94 0 1 1 7.06 12 4.94 4.94 0 0 1 12 7.06Zm0 8.14A3.2 3.2 0 1 0 8.8 12 3.2 3.2 0 0 0 12 15.2Zm5.14-8.34a1.15 1.15 0 1 1-1.15-1.15 1.15 1.15 0 0 1 1.15 1.15Z"
    ></path>
  </svg>
</a>

<style>
  .cn-social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--on-surface-variant);
    transition: color 0.15s ease;
  }
  .cn-social-link:hover {
    color: var(--on-surface);
  }
  .cn-social-link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }
</style>
