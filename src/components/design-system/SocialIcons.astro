<style>
  .cn-social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--on-surface-variant);
    transition: color 0.15s ease;
  }
  .cn-social-link:hover {
    color: var(--on-surface);
  }
  .cn-social-link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }
</style>
